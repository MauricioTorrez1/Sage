{
  "expo": {
    "name": "Sage",
    "slug": "sage",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "sage",
    "userInterfaceStyle": "automatic",
    "updates": {
      "url": "https://u.expo.dev/a633ce7d-8f42-4edb-9c20-b7cade25c901"
    },
    "runtimeVersion": {
      "policy": "sdkVersion"
    },
    "ios": {
      "bundleIdentifier": "mx.sage.app",
      "supportsTablet": false
    },
    "android": {
      "package": "mx.sage.app",
      "adaptiveIcon": {
        "backgroundColor": "#E5ECE6",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#FAF7F2",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 76,
          "dark": {
            "backgroundColor": "#1C1A17"
          }
        }
      ],
      "expo-localization",
      [
        "expo-image-picker",
        {
          "photosPermission": "Sage usa tus fotos para registrar tu progreso físico.",
          "cameraPermission": "Sage usa la cámara para tomar tus fotos de progreso."
        }
      ],
      "expo-notifications"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "a633ce7d-8f42-4edb-9c20-b7cade25c901"
      }
    },
    "owner": "mauriciotorrez"
  }
}
