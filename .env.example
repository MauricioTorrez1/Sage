# Supabase project settings (Dashboard > Settings > API)
# The anon key is safe to ship in the client: every table is protected by RLS.
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Optional donation link shown in Settings (Phase 9)
# EXPO_PUBLIC_DONATION_URL=https://ko-fi.com/your-user

# Only needed to run scripts/ingest-knowledge.mjs (RAG, Phase 14).
# NEVER ship these in the client; they stay on your machine.
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# VOYAGE_API_KEY=your-voyage-ai-key
