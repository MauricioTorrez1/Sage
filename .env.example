# Supabase project settings (Dashboard > Settings > API)
# The anon key is safe to ship in the client: every table is protected by RLS.
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

